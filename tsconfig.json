{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vitepress/client"]
  },
  "include": [
    "docs/.vitepress/**/*.ts",
    "docs/.vitepress/**/*.js",
    "docs/.vitepress/**/*.vue",
    "docs/.vitepress/env.d.ts",
    "env.d.ts",
  ],
  "exclude": [
    "node_modules",
    ".vitepress/dist",
    ".vitepress/cache",
    "docs/.vitepress/dist",
    "docs/.vitepress/cache"
  ]
}
